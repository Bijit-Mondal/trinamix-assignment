          "customReadCSV": "read_csv(csv_data, dtype={\n    'Contract_Tier': str,\n    'Risk_Level': str,\n    'Active_Disruptions': str,\n    'Region': str,\n    'Supplier_Name': str,\n    'Supplier_ID': str,\n    'PO_ID': str,\n    'Country': str,\n    'Product_Category': str\n})"
